@model List<PRJ_SEMANA_03_S01.Models.DetalleCompra>

<h2>DetalleCompra</h2>
<a asp-action="Create" class="btn btn-primary">Nuevo</a>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Id</th>
            <th>Orden</th>
            <th>Producto</th>
            <th>Cantidad</th>
            <th>Costo</th>
            <th>Subtotal</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.iddetallecompra</td>
                <td>@item.idordencompra</td>
                <td>@item.nomproducto</td>
                <td>@item.cantidad</td>
                <td>@item.costounitario</td>
                <td>@item.subtotal</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.iddetallecompra" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.iddetallecompra" class="btn btn-danger btn-sm" onclick="confirmarEliminar(event)">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    function confirmarEliminar(e) {
      e.preventDefault();
      const url = e.currentTarget.href;

      Swal.fire({
        title: "¿Eliminar detalle?",
        text: "Esta acción no se puede deshacer.",
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: "Sí, eliminar",
        cancelButtonText: "Cancelar"
      }).then((result) => {
        if (result.isConfirmed) {
          window.location.href = url;
        }
      });
    }
</script>