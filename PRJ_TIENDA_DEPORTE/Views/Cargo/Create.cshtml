@using System.Globalization
@model PRJ_SEMANA_03_S01.Models.Cargo

<h2>Nuevo Cargo</h2>

<form asp-action="Create" method="post" id="formCreate">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3 col-md-5">
        <label class="form-label">Nombre</label>
        <input asp-for="nomcargo" class="form-control" id="nomcargo" maxlength="50" />
        <span asp-validation-for="nomcargo" class="text-danger"></span>
        <small id="avisoCargo" class="text-danger d-none">No se permite usar ADMIN o ADMINISTRADOR en el nombre del cargo.</small>
    </div>

    <div class="mb-3 col-md-4">
        <label class="form-label">Sueldo</label>
        <input type="text" name="sueldo" id="sueldo" class="form-control"
               value="@(Model?.sueldo.ToString("0.00", CultureInfo.InvariantCulture) == "0.00" ? "" : Model?.sueldo.ToString("0.00", CultureInfo.InvariantCulture))"
               inputmode="decimal" maxlength="12" autocomplete="off" placeholder="1050.20" />
        <span asp-validation-for="sueldo" class="text-danger"></span>
        <small class="text-muted">Use punto decimal. Ejemplo: 1050.20</small>
    </div>


    <div class="mb-3 col-md-4">
        <label class="form-label">Estado</label>
        <select asp-for="estadocargo" class="form-select">
            <option value="ACTIVO" selected="@(Model.estadocargo == "ACTIVO")">ACTIVO</option>
            <option value="INACTIVO" selected="@(Model.estadocargo == "INACTIVO")">INACTIVO</option>
        </select>
        <span asp-validation-for="estadocargo" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <script>
        const txtCargo = document.getElementById('nomcargo');
        const avisoCargo = document.getElementById('avisoCargo');
        const txtSueldo = document.getElementById('sueldo');

        // 🔹 Validar nombres reservados
        function validarCargoReservado() {
            const valor = (txtCargo.value || '').trim().toUpperCase();
            const bloqueado = valor === 'ADMIN' || valor === 'ADMINISTRADOR';
            avisoCargo.classList.toggle('d-none', !bloqueado);
            txtCargo.classList.toggle('is-invalid', bloqueado);
            return !bloqueado;
        }

        // 🔹 Bloquear caracteres no permitidos en nombre
        txtCargo.addEventListener('keypress', function(e) {
            const char = String.fromCharCode(e.which);
            if (!/[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/.test(char)) {
                e.preventDefault();
            }
        });

        // 🔹 Normalizar sueldo (solo números + 1 punto + 2 decimales)
        function normalizarSueldo() {
            let valor = txtSueldo.value || '';

            // eliminar todo lo que no sea número o punto
            valor = valor.replace(/[^\d.]/g, '');

            // permitir solo un punto
            const partes = valor.split('.');
            if (partes.length > 2) {
                valor = partes[0] + '.' + partes[1];
            }

            // limitar decimales a 2
            const nuevasPartes = valor.split('.');
            if (nuevasPartes.length === 2) {
                nuevasPartes[1] = nuevasPartes[1].slice(0, 2);
                valor = nuevasPartes[0] + '.' + nuevasPartes[1];
            }

            // limitar enteros (máx 8)
            if (nuevasPartes[0].length > 8) {
                nuevasPartes[0] = nuevasPartes[0].slice(0, 8);
                valor = nuevasPartes.join('.');
            }

            txtSueldo.value = valor;

            return /^\d+(\.\d{1,2})?$/.test(valor);
        }

        // 🔹 Eventos
        txtCargo.addEventListener('input', validarCargoReservado);
        txtSueldo.addEventListener('input', normalizarSueldo);

        // 🔹 Bloquear pegado inválido en sueldo
        txtSueldo.addEventListener('paste', function(e) {
            e.preventDefault();
        });

        // 🔹 Validación antes de enviar
        document.getElementById('formCreate').addEventListener('submit', function (e) {
            const sueldoValido = normalizarSueldo();
            const cargoValido = validarCargoReservado();

            if (!cargoValido || !sueldoValido) {
                txtSueldo.classList.toggle('is-invalid', !sueldoValido);
                e.preventDefault();
            }
        });
    </script>
}