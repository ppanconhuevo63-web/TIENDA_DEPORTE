@model PRJ_SEMANA_03_S01.Models.UsuarioLogin
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow">
            <div class="card-body p-4">
                <h3 class="text-center mb-3">Ingreso al sistema</h3>
                <p class="text-center text-muted">Tienda Deportiva - MVC .NET 10</p>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Index" method="post">
                    <div class="mb-3">
                        <label asp-for="username" class="form-label">Usuario</label>
                        <input asp-for="username" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="password" class="form-label">Contraseña</label>
                        <input asp-for="password" class="form-control" />
                    </div>
                    <button class="btn btn-primary w-100">Ingresar</button>
                </form>

                <hr />
                <small class="text-muted d-block">Administrador: <strong>admin</strong> / <strong>admin123</strong></small>
                <small class="text-muted d-block">Cajero: <strong>cajero</strong> / <strong>cajero123</strong></small>
            </div>
        </div>
    </div>
</div>
